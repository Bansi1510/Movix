generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VideoType {
  FREE
  PREMIUM
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum Sentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

model Admin {
  id String @id @default(cuid())

  email    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos Video[]
}

model Video {
  id String @id @default(cuid())

  title       String
  description String

  thumbnail         String
  thumbnailPublicId String

  bannerImage    String?
  bannerPublicId String?

  videoUrl      String
  videoPublicId String

  trailerUrl      String?
  trailerPublicId String?

  genre    String
  language String?

  tags String[]

  duration Int

  type VideoType @default(FREE)

  price Float @default(0)

  hasAds Boolean @default(true)

  downloadable Boolean @default(false)

  views Int @default(0)

  isPublished Boolean @default(true)

  uploadedById String
  uploadedBy   Admin  @relation(fields: [uploadedById], references: [id])

  purchases Purchase[]
  analytics Analytics[]
  comments  Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  likes     Like[]

  @@index([uploadedById])
}

model User {
  id String @id @default(cuid())

  name     String?
  email    String  @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  likes     Like[]
  purchases Purchase[]
}

model Purchase {
  id String @id @default(cuid())

  amount Float

  razorpayOrderId   String  @unique
  razorpayPaymentId String? @unique

  status PaymentStatus @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([userId])
}

model Analytics {
  id String @id @default(cuid())

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  views Int @default(0)

  totalWatchTime Int @default(0)

  completionRate Float @default(0)

  createdAt DateTime @default(now())

  @@index([videoId])
  @@index([videoId, createdAt])
}

model Comment {
  id String @id @default(cuid())

  message String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([videoId])
  @@index([userId])
}

model Like {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([videoId])
}
